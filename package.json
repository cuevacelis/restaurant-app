{
  "name": "restaurant-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-webpack": "next dev --webpack",
    "clean": "rm -rf .next node_modules pnpm-lock.yaml && pnpm i",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "infra:setup:dev": "bash infrastructure/setup-aws.sh --stage=dev",
    "infra:setup:prd": "bash infrastructure/setup-aws.sh --stage=prd",
    "infra:destroy:dev": "bash infrastructure/setup-aws.sh --stage=dev --destroy",
    "infra:destroy:prd": "bash infrastructure/setup-aws.sh --stage=prd --destroy",
    "db:triggers:dev": "bash infrastructure/setup-triggers.sh --stage=dev",
    "db:triggers:prd": "bash infrastructure/setup-triggers.sh --stage=prd",
    "db:setup": "node --env-file=.env.local scripts/setup-db.js",
    "db:seed": "node --env-file=.env.local scripts/seed-db.js",
    "db:reset": "pnpm db:setup && pnpm db:seed",
    "db:reset-hard": "node --env-file=.env.local scripts/reset-db-hard.js",
    "db:fix-pass": "node --env-file=.env.local scripts/fix-passwords.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "@trpc/tanstack-react-query": "^11.12.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "mercadopago": "^2.12.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
