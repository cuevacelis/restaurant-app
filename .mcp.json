{
	"mcpServers": {
		"shadcn": {
			"command": "npx",
			"args": [
				"shadcn@latest",
				"mcp"
			]
		},
		"tanstack-doc": {
			"command": "npx",
			"args": [
				"@tanstack/cli",
				"mcp"
			]
		},
		"motion": {
			"command": "npx",
			"args": [
				"-y",
				"https://api.motion.dev/registry.tgz?package=motion-studio-mcp&version=latest"
			]
		}
	}
}
