# Database (AWS RDS PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=your-rds-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# WebSockets (AWS API Gateway WebSocket - set after running infrastructure/setup-aws.sh)
NEXT_PUBLIC_WEBSOCKET_URL=wss://YOUR_API_GATEWAY_ID.execute-api.us-east-1.amazonaws.com/prod

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
