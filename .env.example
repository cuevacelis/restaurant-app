# Base de datos (AWS RDS PostgreSQL)
DB_HOST=your-rds-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=restaurant
DB_USER=postgres
DB_PASSWORD=your-password
# DB_SSL=false   # descomentar si usás PostgreSQL local sin SSL

# Auth — generá uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# AWS (usadas por pnpm infra:setup / infra:destroy)
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_RDS_INSTANCE_ID=restaurant   # identificador de tu instancia RDS

# WebSockets — se completa automáticamente al correr pnpm infra:setup
NEXT_PUBLIC_WEBSOCKET_URL=

# App — URL pública (usada en callbacks de MercadoPago)
NEXT_PUBLIC_APP_URL=http://localhost:3000
